{
  "name": "kestrelcp",
  "displayName": "KestrelCP",
  "description": "Scaffold, test, and commit competitive programming solutions for Kattis, Codeforces, and LeetCode.",
  "version": "0.7.1",
  "publisher": "khoa-doan",
  "author": {
    "name": "Khoa Doan"
  },
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/DNT-Khoa/kestrelcp.git"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "keywords": [
    "competitive-programming",
    "kattis",
    "codeforces",
    "leetcode",
    "java"
  ],
  "categories": [
    "Programming Languages",
    "Testing"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "kestrelcp.init",
        "title": "KestrelCP: Initialize Workspace"
      },
      {
        "command": "kestrelcp.newProblem",
        "title": "KestrelCP: New Problem",
        "icon": "$(add)"
      },
      {
        "command": "kestrelcp.runTests",
        "title": "KestrelCP: Run Tests",
        "icon": "$(play)"
      },
      {
        "command": "kestrelcp.runTestsForCurrent",
        "title": "KestrelCP: Run Tests for Current File"
      },
      {
        "command": "kestrelcp.refetchAllTests",
        "title": "KestrelCP: Refetch All Sample Tests",
        "icon": "$(cloud-download)"
      },
      {
        "command": "kestrelcp.aiCommit",
        "title": "KestrelCP: AI Commit"
      },
      {
        "command": "kestrelcp.runPlayground",
        "title": "KestrelCP: Run Playground",
        "icon": "$(play-circle)"
      },
      {
        "command": "kestrelcp.refreshProblems",
        "title": "KestrelCP: Refresh Problems",
        "icon": "$(refresh)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kestrelcp",
          "title": "KestrelCP",
          "icon": "media/icon-sidebar.svg"
        }
      ]
    },
    "views": {
      "kestrelcp": [
        {
          "id": "kestrelcp.problems",
          "name": "Problems"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "kestrelcp.runTests",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "kestrelcp.newProblem",
          "when": "view == kestrelcp.problems",
          "group": "navigation@1"
        },
        {
          "command": "kestrelcp.refreshProblems",
          "when": "view == kestrelcp.problems",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "kestrelcp.runTests",
          "when": "view == kestrelcp.problems && viewItem == problem",
          "group": "inline"
        },
        {
          "command": "kestrelcp.runPlayground",
          "when": "view == kestrelcp.problems && viewItem == playground",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "KestrelCP",
      "properties": {
        "kestrelcp.pythonPath": {
          "type": "string",
          "default": "python3",
          "description": "Python 3 interpreter used to run new.py / test.py / commit.py."
        },
        "kestrelcp.anthropicApiKey": {
          "type": "string",
          "default": "",
          "description": "Anthropic API key for AI commit messages. Leave blank to inherit from the shell environment."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -w -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.0",
    "typescript": "^5.4.0"
  }
}
