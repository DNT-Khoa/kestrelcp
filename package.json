{
  "name": "kestrelcp",
  "displayName": "KestrelCP",
  "description": "Scaffold, test, submit (LeetCode), and commit competitive programming solutions for Kattis, Codeforces, and LeetCode.",
  "version": "3.1.0",
  "publisher": "khoa-doan",
  "author": {
    "name": "Khoa Doan"
  },
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/DNT-Khoa/kestrelcp.git"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "keywords": [
    "competitive-programming",
    "kattis",
    "codeforces",
    "leetcode",
    "java"
  ],
  "categories": [
    "Programming Languages",
    "Testing"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "kestrelcp.init",
        "title": "KestrelCP: Initialize Workspace"
      },
      {
        "command": "kestrelcp.newProblem",
        "title": "KestrelCP: New Problem"
      },
      {
        "command": "kestrelcp.runTestsForCurrent",
        "title": "KestrelCP: Run Tests for Current Problem",
        "icon": "$(play)"
      },
      {
        "command": "kestrelcp.aiCommit",
        "title": "KestrelCP: AI Commit"
      },
      {
        "command": "kestrelcp.runPlayground",
        "title": "KestrelCP: Run Playground",
        "icon": "$(play-circle)"
      },
      {
        "command": "kestrelcp.searchLeetcode",
        "title": "KestrelCP: Search LeetCode"
      },
      {
        "command": "kestrelcp.submitLeetcode",
        "title": "KestrelCP: Submit to LeetCode",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "kestrelcp.setLeetcodeCookies",
        "title": "KestrelCP: Set LeetCode Cookies"
      },
      {
        "command": "kestrelcp.setAnthropicKey",
        "title": "KestrelCP: Set Anthropic API Key"
      },
      {
        "command": "kestrelcp.refreshDaily",
        "title": "KestrelCP: Refresh Daily Challenge",
        "icon": "$(refresh)"
      },
      {
        "command": "kestrelcp.openOrScaffoldDaily",
        "title": "KestrelCP: Open / Scaffold Today's Daily Challenge"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kestrelcp",
          "title": "KestrelCP",
          "icon": "media/icon-sidebar.svg"
        }
      ]
    },
    "views": {
      "kestrelcp": [
        {
          "id": "kestrelcp.daily",
          "name": "LeetCode Daily"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "kestrelcp.runTestsForCurrent",
          "when": "kestrelcp.activeIsProblem"
        },
        {
          "command": "kestrelcp.submitLeetcode",
          "when": "kestrelcp.activeIsLeetcode"
        },
        {
          "command": "kestrelcp.runPlayground",
          "when": "kestrelcp.activeIsPlayground"
        },
        {
          "command": "kestrelcp.refreshDaily",
          "when": "false"
        },
        {
          "command": "kestrelcp.openOrScaffoldDaily",
          "when": "false"
        }
      ],
      "editor/title": [
        {
          "command": "kestrelcp.runTestsForCurrent",
          "when": "kestrelcp.activeIsProblem",
          "group": "navigation@1"
        },
        {
          "command": "kestrelcp.submitLeetcode",
          "when": "kestrelcp.activeIsLeetcode",
          "group": "navigation@2"
        },
        {
          "command": "kestrelcp.runPlayground",
          "when": "kestrelcp.activeIsPlayground",
          "group": "navigation@1"
        }
      ],
      "view/title": [
        {
          "command": "kestrelcp.refreshDaily",
          "when": "view == kestrelcp.daily",
          "group": "navigation@1"
        }
      ]
    },
    "configuration": {
      "title": "KestrelCP",
      "properties": {
        "kestrelcp.commitModel": {
          "type": "string",
          "default": "claude-haiku-4-5",
          "description": "Anthropic model used to generate commit messages (e.g. claude-haiku-4-5, claude-sonnet-4-6, claude-opus-4-8)."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -w -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.0",
    "typescript": "^5.4.0"
  }
}
